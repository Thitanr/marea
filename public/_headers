/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(), payment=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; manifest-src 'self'; media-src 'self' blob:; worker-src 'self' blob:; frame-ancestors 'none';

/service-worker.js
  Cache-Control: no-cache

# Face model + MediaPipe wasm runtime — immutable, cache forever at the HTTP layer too
/models/*
  Cache-Control: public, max-age=31536000, immutable
/mediapipe/*
  Cache-Control: public, max-age=31536000, immutable
